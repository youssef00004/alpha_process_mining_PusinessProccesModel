<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             targetNamespace="http://www.example.org/epurchase-after"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

  <collaboration id="collab_after">
    <participant id="pool_shopEasy" name="ShopEasy – E-Purchase Process (AFTER Enhancement)" processRef="proc_after"/>
  </collaboration>

  <process id="proc_after" name="E-Purchase After" isExecutable="false">

    <laneSet id="laneSet1">
      <lane id="lane_customer" name="Customer">
        <flowNodeRef>start_visit</flowNodeRef>
        <flowNodeRef>task_browse</flowNodeRef>
        <flowNodeRef>task_addcart</flowNodeRef>
        <flowNodeRef>task_reviewcart</flowNodeRef>
        <flowNodeRef>task_address</flowNodeRef>
        <flowNodeRef>task_paymethod</flowNodeRef>
        <flowNodeRef>task_complaint</flowNodeRef>
        <flowNodeRef>task_review</flowNodeRef>
        <flowNodeRef>end_complete</flowNodeRef>
      </lane>
      <lane id="lane_ordermgmt" name="Order Management System">
        <flowNodeRef>task_earlystock</flowNodeRef>
        <flowNodeRef>gw_stock</flowNodeRef>
        <flowNodeRef>task_nostock_notify</flowNodeRef>
        <flowNodeRef>end_nostock</flowNodeRef>
        <flowNodeRef>task_reserve</flowNodeRef>
        <flowNodeRef>task_invoice</flowNodeRef>
      </lane>
      <lane id="lane_payment" name="Payment Gateway">
        <flowNodeRef>task_processpay</flowNodeRef>
        <flowNodeRef>gw_payment</flowNodeRef>
        <flowNodeRef>task_payfail_notify</flowNodeRef>
        <flowNodeRef>gw_retry</flowNodeRef>
        <flowNodeRef>end_payfail</flowNodeRef>
        <flowNodeRef>task_payconfirm</flowNodeRef>
        <flowNodeRef>task_fraud</flowNodeRef>
        <flowNodeRef>gw_fraud</flowNodeRef>
        <flowNodeRef>task_fraud_hold</flowNodeRef>
        <flowNodeRef>end_fraud</flowNodeRef>
      </lane>
      <lane id="lane_warehouse" name="Warehouse and Fulfillment">
        <flowNodeRef>task_pickpack</flowNodeRef>
        <flowNodeRef>task_assigncarrier</flowNodeRef>
        <flowNodeRef>gw_par_open</flowNodeRef>
        <flowNodeRef>task_dispatch</flowNodeRef>
        <flowNodeRef>task_inv_update</flowNodeRef>
        <flowNodeRef>gw_par_close</flowNodeRef>
      </lane>
      <lane id="lane_shipping" name="Shipping Partner">
        <flowNodeRef>task_pickup</flowNodeRef>
        <flowNodeRef>task_intransit</flowNodeRef>
        <flowNodeRef>timer_deadline</flowNodeRef>
        <flowNodeRef>gw_delivered</flowNodeRef>
        <flowNodeRef>task_deliveryconfirm</flowNodeRef>
        <flowNodeRef>msg_delayalert</flowNodeRef>
        <flowNodeRef>task_delay_notify</flowNodeRef>
        <flowNodeRef>gw_comp_open</flowNodeRef>
        <flowNodeRef>task_coupon</flowNodeRef>
        <flowNodeRef>task_delay_sms</flowNodeRef>
        <flowNodeRef>gw_comp_close</flowNodeRef>
        <flowNodeRef>gw_customer_decision</flowNodeRef>
        <flowNodeRef>task_refund</flowNodeRef>
        <flowNodeRef>end_cancelled_delay</flowNodeRef>
        <flowNodeRef>task_reschedule</flowNodeRef>
        <flowNodeRef>timer_redelivery</flowNodeRef>
        <flowNodeRef>gw_2nd_delivery</flowNodeRef>
        <flowNodeRef>task_agent_escalate</flowNodeRef>
      </lane>
    </laneSet>

    <!-- ===== CUSTOMER ===== -->
    <startEvent id="start_visit" name="Customer Visits Platform">
      <outgoing>sf1</outgoing>
    </startEvent>
    <userTask id="task_browse" name="Browse and Search Products">
      <incoming>sf1</incoming><outgoing>sf2</outgoing>
    </userTask>
    <userTask id="task_addcart" name="Add Item to Cart">
      <incoming>sf2</incoming><outgoing>sf3</outgoing>
    </userTask>
    <userTask id="task_reviewcart" name="Review Cart and Proceed to Checkout">
      <incoming>mf_reserve_to_review</incoming><outgoing>sf4</outgoing>
    </userTask>
    <userTask id="task_address" name="Enter Shipping Address">
      <incoming>sf4</incoming><outgoing>sf5</outgoing>
    </userTask>
    <userTask id="task_paymethod" name="Select Payment Method">
      <incoming>sf5</incoming><outgoing>mf_pay_to_gateway</outgoing>
    </userTask>
    <userTask id="task_complaint" name="Customer Files Complaint: Wait or Cancel">
      <incoming>mf_delay_to_complaint</incoming><outgoing>mf_complaint_to_decision</outgoing>
    </userTask>
    <userTask id="task_review" name="Customer Reviews and Rates Order">
      <incoming>mf_confirm_to_review</incoming><outgoing>sf_review_end</outgoing>
    </userTask>
    <endEvent id="end_complete" name="Order Complete">
      <incoming>sf_review_end</incoming>
    </endEvent>

    <!-- ===== ORDER MANAGEMENT ===== -->
    <serviceTask id="task_earlystock" name="[NEW] Early Stock Check">
      <incoming>mf_cart_to_stock</incoming><outgoing>sf6</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_stock" name="Stock Available?">
      <incoming>sf6</incoming><outgoing>sf_stock_yes</outgoing><outgoing>sf_stock_no</outgoing>
    </exclusiveGateway>
    <sendTask id="task_nostock_notify" name="Notify Customer – Out of Stock">
      <incoming>sf_stock_no</incoming><outgoing>sf_nostock_end</outgoing>
    </sendTask>
    <endEvent id="end_nostock" name="Order Cancelled – No Stock">
      <incoming>sf_nostock_end</incoming><terminateEventDefinition/>
    </endEvent>
    <serviceTask id="task_reserve" name="[NEW] Reserve Item in Inventory (15 min hold)">
      <incoming>sf_stock_yes</incoming><outgoing>mf_reserve_to_review</outgoing>
    </serviceTask>
    <serviceTask id="task_invoice" name="Generate Order ID and Invoice">
      <incoming>sf_addr_to_invoice</incoming><outgoing>mf_invoice_to_payment</outgoing>
    </serviceTask>

    <!-- ===== PAYMENT ===== -->
    <serviceTask id="task_processpay" name="Process Payment Authorization">
      <incoming>mf_pay_to_gateway</incoming>
      <incoming>mf_invoice_to_payment</incoming>
      <incoming>sf_retry_back</incoming>
      <outgoing>sf7</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_payment" name="Payment Successful?">
      <incoming>sf7</incoming><outgoing>sf_pay_yes</outgoing><outgoing>sf_pay_no</outgoing>
    </exclusiveGateway>
    <sendTask id="task_payfail_notify" name="Notify Customer – Payment Failed">
      <incoming>sf_pay_no</incoming><outgoing>sf_to_retry</outgoing>
    </sendTask>
    <exclusiveGateway id="gw_retry" name="[NEW] Retry Attempt less than 3?">
      <incoming>sf_to_retry</incoming><outgoing>sf_retry_back</outgoing><outgoing>sf_retry_end</outgoing>
    </exclusiveGateway>
    <endEvent id="end_payfail" name="Order Failed – Max Payment Retries">
      <incoming>sf_retry_end</incoming><terminateEventDefinition/>
    </endEvent>
    <sendTask id="task_payconfirm" name="Send Payment Confirmation to Customer">
      <incoming>sf_pay_yes</incoming><outgoing>sf_pay_to_fraud</outgoing>
    </sendTask>
    <serviceTask id="task_fraud" name="[NEW] Fraud Screening and Risk Check">
      <incoming>sf_pay_to_fraud</incoming><outgoing>sf_fraud_gw</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_fraud" name="[NEW] Fraud Risk Detected?">
      <incoming>sf_fraud_gw</incoming><outgoing>sf_fraud_yes</outgoing><outgoing>sf_fraud_no</outgoing>
    </exclusiveGateway>
    <userTask id="task_fraud_hold" name="[NEW] Hold Order for Manual Review">
      <incoming>sf_fraud_yes</incoming><outgoing>sf_fraud_end</outgoing>
    </userTask>
    <endEvent id="end_fraud" name="Order Rejected – Fraud">
      <incoming>sf_fraud_end</incoming><terminateEventDefinition/>
    </endEvent>

    <!-- ===== WAREHOUSE ===== -->
    <serviceTask id="task_pickpack" name="Pick and Pack Items">
      <incoming>mf_fraud_to_warehouse</incoming><outgoing>sf8</outgoing>
    </serviceTask>
    <serviceTask id="task_assigncarrier" name="Assign Shipping Carrier">
      <incoming>sf8</incoming><outgoing>sf9</outgoing>
    </serviceTask>
    <parallelGateway id="gw_par_open" name="[NEW] Parallel Split">
      <incoming>sf9</incoming><outgoing>sf_par_dispatch</outgoing><outgoing>sf_par_inv</outgoing>
    </parallelGateway>
    <sendTask id="task_dispatch" name="Dispatch Order to Shipping Partner">
      <incoming>sf_par_dispatch</incoming><outgoing>sf_par_dispatch_join</outgoing>
    </sendTask>
    <serviceTask id="task_inv_update" name="[NEW] Update Inventory System">
      <incoming>sf_par_inv</incoming><outgoing>sf_par_inv_join</outgoing>
    </serviceTask>
    <parallelGateway id="gw_par_close" name="[NEW] Parallel Join">
      <incoming>sf_par_dispatch_join</incoming><incoming>sf_par_inv_join</incoming>
      <outgoing>mf_warehouse_to_shipping</outgoing>
    </parallelGateway>

    <!-- ===== SHIPPING ===== -->
    <serviceTask id="task_pickup" name="Pick Up Package from Warehouse">
      <incoming>mf_warehouse_to_shipping</incoming><outgoing>sf10</outgoing>
    </serviceTask>
    <serviceTask id="task_intransit" name="In Transit – Update Tracking">
      <incoming>sf10</incoming><outgoing>sf11</outgoing>
    </serviceTask>
    <intermediateCatchEvent id="timer_deadline" name="Expected Delivery Deadline (3 Days)">
      <incoming>sf11</incoming><outgoing>sf12</outgoing>
      <timerEventDefinition><timeDuration>P3D</timeDuration></timerEventDefinition>
    </intermediateCatchEvent>
    <exclusiveGateway id="gw_delivered" name="Delivered on Time?">
      <incoming>sf12</incoming><outgoing>sf_del_yes</outgoing><outgoing>sf_del_no</outgoing>
    </exclusiveGateway>
    <sendTask id="task_deliveryconfirm" name="Send Delivery Confirmation and Receipt">
      <incoming>sf_del_yes</incoming>
      <incoming>sf_2nd_del_yes</incoming>
      <outgoing>mf_confirm_to_review</outgoing>
    </sendTask>
    <intermediateCatchEvent id="msg_delayalert" name="Delay Alert Triggered">
      <incoming>sf_del_no</incoming><outgoing>sf13</outgoing>
      <messageEventDefinition/>
    </intermediateCatchEvent>
    <sendTask id="task_delay_notify" name="Notify Customer of Delay">
      <incoming>sf13</incoming><outgoing>sf_delay_par_open</outgoing>
    </sendTask>
    <parallelGateway id="gw_comp_open" name="[NEW] Parallel Split – Compensation">
      <incoming>sf_delay_par_open</incoming>
      <outgoing>sf_to_coupon</outgoing><outgoing>sf_to_sms</outgoing>
    </parallelGateway>
    <serviceTask id="task_coupon" name="[NEW] Generate Discount Coupon (Compensation)">
      <incoming>sf_to_coupon</incoming><outgoing>sf_coupon_join</outgoing>
    </serviceTask>
    <sendTask id="task_delay_sms" name="Send Delay SMS and Email to Customer">
      <incoming>sf_to_sms</incoming><outgoing>sf_sms_join</outgoing>
    </sendTask>
    <parallelGateway id="gw_comp_close" name="[NEW] Parallel Join – Compensation">
      <incoming>sf_coupon_join</incoming><incoming>sf_sms_join</incoming>
      <outgoing>mf_delay_to_complaint</outgoing>
    </parallelGateway>
    <exclusiveGateway id="gw_customer_decision" name="Customer Decision?">
      <incoming>mf_complaint_to_decision</incoming>
      <outgoing>sf_dec_cancel</outgoing><outgoing>sf_dec_wait</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_refund" name="Process Refund">
      <incoming>sf_dec_cancel</incoming><outgoing>sf_refund_end</outgoing>
    </serviceTask>
    <endEvent id="end_cancelled_delay" name="Order Cancelled – Delay">
      <incoming>sf_refund_end</incoming><terminateEventDefinition/>
    </endEvent>
    <serviceTask id="task_reschedule" name="Reschedule Delivery">
      <incoming>sf_dec_wait</incoming><outgoing>sf_to_timer2</outgoing>
    </serviceTask>
    <intermediateCatchEvent id="timer_redelivery" name="[NEW] Re-Delivery Deadline (48 Hours)">
      <incoming>sf_to_timer2</incoming><outgoing>sf_timer2_gw</outgoing>
      <timerEventDefinition><timeDuration>PT48H</timeDuration></timerEventDefinition>
    </intermediateCatchEvent>
    <exclusiveGateway id="gw_2nd_delivery" name="[NEW] Delivered on Reschedule?">
      <incoming>sf_timer2_gw</incoming>
      <outgoing>sf_2nd_del_yes</outgoing><outgoing>sf_2nd_del_no</outgoing>
    </exclusiveGateway>
    <userTask id="task_agent_escalate" name="[NEW] Escalate to Customer Service Agent">
      <incoming>sf_2nd_del_no</incoming>
    </userTask>

    <!-- ===== SEQUENCE FLOWS ===== -->
    <sequenceFlow id="sf1" sourceRef="start_visit" targetRef="task_browse"/>
    <sequenceFlow id="sf2" sourceRef="task_browse" targetRef="task_addcart"/>
    <sequenceFlow id="sf3" sourceRef="task_addcart" targetRef="task_earlystock"/>
    <sequenceFlow id="mf_cart_to_stock" sourceRef="task_addcart" targetRef="task_earlystock"/>
    <sequenceFlow id="sf4" sourceRef="task_reviewcart" targetRef="task_address"/>
    <sequenceFlow id="sf5" sourceRef="task_address" targetRef="task_paymethod"/>
    <sequenceFlow id="sf_review_end" sourceRef="task_review" targetRef="end_complete"/>
    <sequenceFlow id="sf_addr_to_invoice" sourceRef="task_address" targetRef="task_invoice"/>

    <sequenceFlow id="sf6" sourceRef="task_earlystock" targetRef="gw_stock"/>
    <sequenceFlow id="sf_stock_yes" name="YES" sourceRef="gw_stock" targetRef="task_reserve"/>
    <sequenceFlow id="sf_stock_no" name="NO" sourceRef="gw_stock" targetRef="task_nostock_notify"/>
    <sequenceFlow id="sf_nostock_end" sourceRef="task_nostock_notify" targetRef="end_nostock"/>
    <sequenceFlow id="mf_reserve_to_review" sourceRef="task_reserve" targetRef="task_reviewcart"/>
    <sequenceFlow id="mf_invoice_to_payment" sourceRef="task_invoice" targetRef="task_processpay"/>

    <sequenceFlow id="mf_pay_to_gateway" sourceRef="task_paymethod" targetRef="task_processpay"/>
    <sequenceFlow id="sf7" sourceRef="task_processpay" targetRef="gw_payment"/>
    <sequenceFlow id="sf_pay_yes" name="YES" sourceRef="gw_payment" targetRef="task_payconfirm"/>
    <sequenceFlow id="sf_pay_no" name="NO" sourceRef="gw_payment" targetRef="task_payfail_notify"/>
    <sequenceFlow id="sf_to_retry" sourceRef="task_payfail_notify" targetRef="gw_retry"/>
    <sequenceFlow id="sf_retry_back" name="YES – Retry" sourceRef="gw_retry" targetRef="task_processpay"/>
    <sequenceFlow id="sf_retry_end" name="NO – Max Reached" sourceRef="gw_retry" targetRef="end_payfail"/>
    <sequenceFlow id="sf_pay_to_fraud" sourceRef="task_payconfirm" targetRef="task_fraud"/>
    <sequenceFlow id="sf_fraud_gw" sourceRef="task_fraud" targetRef="gw_fraud"/>
    <sequenceFlow id="sf_fraud_yes" name="YES – Risky" sourceRef="gw_fraud" targetRef="task_fraud_hold"/>
    <sequenceFlow id="sf_fraud_no" name="NO – Safe" sourceRef="gw_fraud" targetRef="task_pickpack"/>
    <sequenceFlow id="sf_fraud_end" sourceRef="task_fraud_hold" targetRef="end_fraud"/>
    <sequenceFlow id="mf_fraud_to_warehouse" sourceRef="gw_fraud" targetRef="task_pickpack"/>

    <sequenceFlow id="sf8" sourceRef="task_pickpack" targetRef="task_assigncarrier"/>
    <sequenceFlow id="sf9" sourceRef="task_assigncarrier" targetRef="gw_par_open"/>
    <sequenceFlow id="sf_par_dispatch" sourceRef="gw_par_open" targetRef="task_dispatch"/>
    <sequenceFlow id="sf_par_inv" sourceRef="gw_par_open" targetRef="task_inv_update"/>
    <sequenceFlow id="sf_par_dispatch_join" sourceRef="task_dispatch" targetRef="gw_par_close"/>
    <sequenceFlow id="sf_par_inv_join" sourceRef="task_inv_update" targetRef="gw_par_close"/>
    <sequenceFlow id="mf_warehouse_to_shipping" sourceRef="gw_par_close" targetRef="task_pickup"/>

    <sequenceFlow id="sf10" sourceRef="task_pickup" targetRef="task_intransit"/>
    <sequenceFlow id="sf11" sourceRef="task_intransit" targetRef="timer_deadline"/>
    <sequenceFlow id="sf12" sourceRef="timer_deadline" targetRef="gw_delivered"/>
    <sequenceFlow id="sf_del_yes" name="YES" sourceRef="gw_delivered" targetRef="task_deliveryconfirm"/>
    <sequenceFlow id="sf_del_no" name="NO" sourceRef="gw_delivered" targetRef="msg_delayalert"/>
    <sequenceFlow id="sf13" sourceRef="msg_delayalert" targetRef="task_delay_notify"/>
    <sequenceFlow id="sf_delay_par_open" sourceRef="task_delay_notify" targetRef="gw_comp_open"/>
    <sequenceFlow id="sf_to_coupon" sourceRef="gw_comp_open" targetRef="task_coupon"/>
    <sequenceFlow id="sf_to_sms" sourceRef="gw_comp_open" targetRef="task_delay_sms"/>
    <sequenceFlow id="sf_coupon_join" sourceRef="task_coupon" targetRef="gw_comp_close"/>
    <sequenceFlow id="sf_sms_join" sourceRef="task_delay_sms" targetRef="gw_comp_close"/>
    <sequenceFlow id="mf_delay_to_complaint" sourceRef="gw_comp_close" targetRef="task_complaint"/>
    <sequenceFlow id="mf_complaint_to_decision" sourceRef="task_complaint" targetRef="gw_customer_decision"/>
    <sequenceFlow id="sf_dec_cancel" name="CANCEL" sourceRef="gw_customer_decision" targetRef="task_refund"/>
    <sequenceFlow id="sf_dec_wait" name="WAIT" sourceRef="gw_customer_decision" targetRef="task_reschedule"/>
    <sequenceFlow id="sf_refund_end" sourceRef="task_refund" targetRef="end_cancelled_delay"/>
    <sequenceFlow id="sf_to_timer2" sourceRef="task_reschedule" targetRef="timer_redelivery"/>
    <sequenceFlow id="sf_timer2_gw" sourceRef="timer_redelivery" targetRef="gw_2nd_delivery"/>
    <sequenceFlow id="sf_2nd_del_yes" name="YES" sourceRef="gw_2nd_delivery" targetRef="task_deliveryconfirm"/>
    <sequenceFlow id="sf_2nd_del_no" name="NO – Escalate" sourceRef="gw_2nd_delivery" targetRef="task_agent_escalate"/>
    <sequenceFlow id="mf_confirm_to_review" sourceRef="task_deliveryconfirm" targetRef="task_review"/>

  </process>

  <!-- ===== DIAGRAM INTERCHANGE ===== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_after">
    <bpmndi:BPMNPlane id="BPMNPlane_after" bpmnElement="collab_after">

      <!-- POOL -->
      <bpmndi:BPMNShape id="shape_pool" bpmnElement="pool_shopEasy" isHorizontal="true">
        <omgdc:Bounds x="80" y="80" width="3400" height="1200"/>
      </bpmndi:BPMNShape>

      <!-- LANES -->
      <bpmndi:BPMNShape id="shape_lane_customer" bpmnElement="lane_customer" isHorizontal="true">
        <omgdc:Bounds x="110" y="80" width="3370" height="170"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_ordermgmt" bpmnElement="lane_ordermgmt" isHorizontal="true">
        <omgdc:Bounds x="110" y="250" width="3370" height="190"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_payment" bpmnElement="lane_payment" isHorizontal="true">
        <omgdc:Bounds x="110" y="440" width="3370" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_warehouse" bpmnElement="lane_warehouse" isHorizontal="true">
        <omgdc:Bounds x="110" y="640" width="3370" height="190"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_shipping" bpmnElement="lane_shipping" isHorizontal="true">
        <omgdc:Bounds x="110" y="830" width="3370" height="450"/>
      </bpmndi:BPMNShape>

      <!-- CUSTOMER SHAPES -->
      <bpmndi:BPMNShape id="s_start" bpmnElement="start_visit">
        <omgdc:Bounds x="162" y="147" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="140" y="188" width="80" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_browse" bpmnElement="task_browse">
        <omgdc:Bounds x="250" y="130" width="130" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_addcart" bpmnElement="task_addcart">
        <omgdc:Bounds x="440" y="130" width="130" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_reviewcart" bpmnElement="task_reviewcart">
        <omgdc:Bounds x="760" y="130" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_address" bpmnElement="task_address">
        <omgdc:Bounds x="960" y="130" width="130" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_paymethod" bpmnElement="task_paymethod">
        <omgdc:Bounds x="1260" y="130" width="130" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_complaint" bpmnElement="task_complaint">
        <omgdc:Bounds x="2550" y="130" width="150" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_review" bpmnElement="task_review">
        <omgdc:Bounds x="2990" y="130" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_end_complete" bpmnElement="end_complete">
        <omgdc:Bounds x="3202" y="147" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="3180" y="188" width="80" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ORDER MGMT SHAPES -->
      <bpmndi:BPMNShape id="s_earlystock" bpmnElement="task_earlystock">
        <omgdc:Bounds x="440" y="300" width="150" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_gw_stock" bpmnElement="gw_stock" isMarkerVisible="true">
        <omgdc:Bounds x="650" y="310" width="50" height="50"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="630" y="365" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_nostock_notify" bpmnElement="task_nostock_notify">
        <omgdc:Bounds x="650" y="258" width="140" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_end_nostock" bpmnElement="end_nostock">
        <omgdc:Bounds x="852" y="265" width="36" height="36"/>
        <bpmndi:BPMNLabel><omgdc:Bounds x="828" y="305" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_reserve" bpmnElement="task_reserve">
        <omgdc:Bounds x="760" y="300" width="160" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_invoice" bpmnElement="task_invoice">
        <omgdc:Bounds x="1100" y="300" width="140" height="70"/>
      </bpmndi:BPMNShape>

      <!-- PAYMENT SHAPES -->
      <bpmndi:BPMNShape id="s_processpay" bpmnElement="task_processpay">
